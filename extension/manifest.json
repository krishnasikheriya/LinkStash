{
  "manifest_version": 3,
  "name": "LinkStash Quick Save",
  "version": "1.0",
  "description": "Quickly save the current tab to your LinkStash account.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to LinkStash"
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ]
}
